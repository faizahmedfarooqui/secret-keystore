# AWS KMS Configuration (never encrypted). KMS_KEY_ID can be symmetric or asymmetric (RSA); RSA uses envelope encryption (no size limit).
KMS_KEY_ID=arn:aws:kms:us-east-1:123456789012:key/your-key-id-here
AWS_REGION=us-east-1

# Secrets to encrypt (run `npm run encrypt:keys` after filling these)
API_KEY=sk-your-api-key-here
JWT_SECRET=your-jwt-secret-here
WEBHOOK_SECRET=whsec_your-webhook-secret-here

# Optional: For local development without IAM roles
# Uncomment and fill these, then use `npm run encrypt:local`
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key

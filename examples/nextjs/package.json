{
  "name": "@faizahmedfarooqui/nextjs-secret-keystore-example",
  "version": "1.0.0",
  "description": "Next.js example app demonstrating @faizahmedfarooqui/secret-keystore integration",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "encrypt": "npx @faizahmedfarooqui/secret-keystore encrypt --kms-key-id=\"$KMS_KEY_ID\" --path=\"./.env.local\"",
    "encrypt:keys": "npx @faizahmedfarooqui/secret-keystore encrypt --kms-key-id=\"$KMS_KEY_ID\" --keys=\"API_KEY,JWT_SECRET,WEBHOOK_SECRET\" --path=\"./.env.local\"",
    "encrypt:local": "npx @faizahmedfarooqui/secret-keystore encrypt --kms-key-id=\"$KMS_KEY_ID\" --keys=\"API_KEY,JWT_SECRET,WEBHOOK_SECRET\" --path=\"./.env.local\" --use-credentials"
  },
  "dependencies": {
    "@faizahmedfarooqui/secret-keystore": "file:../../",
    "next": "^14.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "^5.0.0"
  }
}

